- name: omero searchengine | dump projects
  become: yes
  community.docker.docker_container:
    image: "{{ searchengine_docker_image }}"
    name: "dump_projects_{{ dump_output_format }}{{ cluster_id | default(omit) }}"
    cleanup: True
    command: "dump_searchengine_data -d {{ default_datasource }} -r project  -f {{ dump_output_format }} -t {{ data_dump_folder }}/{{ default_datasource }}/{{ dump_output_format }} -o True"
    networks:
      - name: "{{ searchengine_network }}"
    #restart: "{{ searchengine_conf_status | changed }}"
    state: started
    volumes:
      - "{{ apps_folder }}/searchengine/searchengine/:/etc/searchengine/"
      - "{{ apps_folder }}/searchengine/searchengine/cachedata:/etc/searchengine/cachedata"
      - "{{ apps_folder }}/searchengine/searchengine/logs/:/opt/app-root/src/logs/"
      - "{{ apps_folder }}/data_dump:/data/data_dump"